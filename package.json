{
  "name": "kursor-platform",
  "version": "2.0.0",
  "description": "KURSOR — школа программирования: Node.js + Express + SQLite + JWT + WebSocket",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
    "init-db": "node server/init-db.js",
    "test": "node --test",
    "backup": "node server/backup.js",
    "restore": "node server/restore-backup.js",
    "migrate": "node server/migrate.js"
  },
  "dependencies": {
    "bcryptjs": "3.0.3",
    "better-sqlite3": "12.11.1",
    "busboy": "1.6.0",
    "compression": "1.8.1",
    "cors": "2.8.6",
    "dotenv": "17.4.2",
    "express": "4.22.2",
    "jsonwebtoken": "9.0.3",
    "ws": "8.21.1",
    "zod": "4.1.12"
  },
  "engines": {
    "node": ">=20.19 <25"
  }
}
